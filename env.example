BOT_TOKEN=123456789:ABCdefGhIJKlmnoPQRstuVWxyz_example
OPENAI_KEY=sk-or-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MAX_COMPLETION_TOKENS=500
MODEL="openai/gpt-oss-120b"
BASE_URL="https://openrouter.ai/api/v1"

# Yandex Cloud SpeechKit (optional, for voice recognition / STT)
YC_API_KEY=
YC_FOLDER_ID=

# ElevenLabs (optional, for voice responses / TTS)
ELEVENLABS_API_KEY=
# Default: Rachel voice (calm female). Override with any ElevenLabs voice ID.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Logging (pino)
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Audit log retention — two independent guards, whichever is stricter applies first
# Keep rows for this many days (default: 90)
AUDIT_RETENTION_DAYS=90
# Keep at most this many rows total (default: 100 000 ≈ ~20 MB)
AUDIT_MAX_ROWS=100000
