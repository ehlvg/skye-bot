BOT_TOKEN=123456789:ABCdefGhIJKlmnoPQRstuVWxyz_example
# Optional SOCKS5 proxy for Telegram API (e.g. when Telegram is blocked)
# BOT_PROXY=socks5://user:pass@host:port
OPENAI_KEY=sk-or-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MAX_COMPLETION_TOKENS=500
MODEL="openai/gpt-oss-120b"
BASE_URL="https://openrouter.ai/api/v1"

# Image generation provider (used by /image and image editing).
# Independent from chat — fill these in if your chat provider doesn't support
# OpenRouter's chat-completions image modality (e.g. when BASE_URL points to
# Ollama). If left empty, falls back to BASE_URL/OPENAI_KEY above.
# Recommended: OpenRouter with the Gemini image model.
IMAGE_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Yandex Cloud SpeechKit — single Api-Key drives both STT and TTS.
# Get one at https://aistudio.yandex.ru (Service Account → Api-Key).
YC_API_KEY=
YC_FOLDER_ID=

# TTS voice settings (Yandex SpeechKit). Optional — sensible defaults below.
# Voice catalogue: https://aistudio.yandex.ru/docs/ru/speechkit/tts/voices.html
# Russian options include: jane, omazh, alena, oksana, zahar, ermil, filipp
YC_TTS_VOICE=jane
# Emotion: neutral | good | evil | strict | friendly (voice-dependent)
YC_TTS_EMOTION=neutral
# BCP-47 language tag — ru-RU | en-US | tr-TR | kk-KK | uz-UZ ...
YC_TTS_LANG=ru-RU
# Playback speed: 0.1 – 3.0 (1.0 is normal)
YC_TTS_SPEED=1.0

# Logging (pino)
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Audit log retention — two independent guards, whichever is stricter applies first
# Keep rows for this many days (default: 90)
AUDIT_RETENTION_DAYS=90
# Keep at most this many rows total (default: 100 000 ≈ ~20 MB)
AUDIT_MAX_ROWS=100000

# MCP (Model Context Protocol) — path to mcp.json config file
# Defaults to ./mcp.json in the project root
# MCP_CONFIG_PATH=./mcp.json
#
# For HTTP MCP servers, set inputs as environment variables.
# For example, if mcp.json contains "Authorization": "Bearer ${input:github_mcp_pat}",
# add the PAT here using the input id as the variable name:
# github_mcp_pat=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Settings Panel (Telegram Mini App)
# Public URL where the Mini App is accessible (set in BotFather too)
WEBAPP_URL=http://localhost:3001
# Port for the panel web server
WEBAPP_PORT=3001

# Workspace (persistent code execution container per user, Docker-based)
# Directory on host where per-user workspaces are stored
WORKSPACE_BASE_DIR=/data/workspaces
# Docker image name for workspaces (build with: docker build -f Dockerfile.workspace -t skye-workspace:latest .)
WORKSPACE_IMAGE=skye-workspace:latest
# Resource limits per container
WORKSPACE_MEMORY_LIMIT=512m
WORKSPACE_CPU_LIMIT=1
# Command execution timeout in seconds
WORKSPACE_TIMEOUT_SEC=30

# Skills (Agent Skills loaded per user from uploaded SKILL.md files)
# Directory on host where user skill files are stored
SKILLS_BASE_DIR=/data/skills
