{
  "name": "skye-bot",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:pretty": "bun --watch src/index.ts 2>&1 | bunx pino-pretty --colorize --translateTime",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.9",
    "bun-types": "^1.3.11",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "lefthook": "^2.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "grammy": "^1.39.3",
    "openai": "^6.17.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
